# Keep context small — large monorepo uploads can hit Railway Docker build timeouts.
.git
.github
tmp
audits
**/node_modules
**/.env
**/.env.*
!**/.env.example

# Other apps (not part of this Medusa image)
shopify-headless
web-next
wireframes

# Vite storefront — Dockerfile copies only web/public/images explicitly
web/src
web/dist
web/node_modules
# Seed assets only use tees/ + hero/; shrink context further
web/public/images/proof

# Docs / brand files at repo root (folder name includes a trailing space)
*.md
HORO_Brand_Guidelines_v2.3_Consolidated.md
Guidelines 

# Next / Vercel config for other deploys (not used in this image)
vercel.json

web-next/.next
shopify-headless/.next
