{
  "name": "horo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:seo-build && vite build && npm run verify:seo-assets",
    "validate:seo-build": "node ./scripts/validate-seo-build.mjs",
    "verify:seo-assets": "node ./scripts/verify-seo-assets.mjs",
