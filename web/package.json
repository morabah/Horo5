{
  "name": "horo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:seo-build && vite build && npm run verify:seo-assets",
    "validate:seo-build": "node ./scripts/validate-seo-build.mjs",
    "verify:seo-assets": "node ./scripts/verify-seo-assets.mjs",
    "test:seo": "node ./scripts/test-seo.mjs",
    "test:analytics": "node ./scripts/test-analytics.mjs",
    "test:a11y": "node ./scripts/test-a11y.mjs",
    "ci": "npx tsc --noEmit && npm run build && npm run test:a11y",
    "validate:release-config": "node ./scripts/validate-release-config.mjs",
    "build:release": "npm run validate:release-config && npm run build",
    "preview": "vite preview",
    "preview:a11y": "vite preview --port 4173 --strictPort --host localhost",
    "preview:e2e": "vite preview --port 4174 --strictPort --host localhost",
    "test:e2e": "VITE_SITE_URL=${VITE_SITE_URL:-https://horo.local} npm run build && node ./scripts/test-e2e-tasks.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.4.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
