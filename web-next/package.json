{
  "name": "web-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:public": "node scripts/sync-shared-public.mjs",
    "dev": "npm run sync:public && next dev --webpack",
    "dev:local": "npm run sync:public && node scripts/free-dev-ports.mjs && concurrently -k -n backend,next -c cyan,magenta \"npm run dev --prefix ../medusa-backend\" \"wait-on http://127.0.0.1:9000/health && dotenv -e .env.local -v NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000 -- next dev --webpack\"",
    "dev:railway": "npm run sync:public && dotenv -e .env.railway -e .env.railway.local -- next dev --webpack",
    "build": "npm run sync:public && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test:unit": "jest --config jest.config.cjs --runInBand",
    "integration:catalog": "node scripts/integration-catalog-contract.mjs",
    "smoke:medusa": "node scripts/smoke-medusa.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.13.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@playwright/test": "^1.51.0",
    "@types/react-dom": "^19",
    "@types/webpack": "^5.28.5",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "jest": "^29.7.0",
    "eslint-config-next": "16.2.3",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
