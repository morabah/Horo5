# Copy to .env.local and set (no trailing slash on URLs).
#
# Dev backend selection (web-next; run commands from this web-next/ directory):
#   npm run dev:local   → frees ports 9000/3000 if busy, starts ../medusa-backend, waits for /health, then Next (Ctrl+C stops both)
#   npm run dev:railway → Next only; uses .env.railway + optional .env.railway.local after .env.local
#
# Local Medusa: http://localhost:9000
# Production Medusa (Railway): https://horo5-production.up.railway.app
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# From Medusa Admin → Settings → Publishable API Keys (must match the backend above)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=
# Shared with medusa-backend: Medusa subscribers POST here after product/taxonomy edits to bust Next fetch cache.
# Required on Medusa: STOREFRONT_REVALIDATE_URL (e.g. http://localhost:3000/api/revalidate/storefront for dev:local)
# and the same STOREFRONT_REVALIDATE_SECRET in both services.
# STOREFRONT_REVALIDATE_SECRET=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional support / social (see storefront/data/domain-config.ts)
# NEXT_PUBLIC_HORO_INSTAGRAM_URL=
# NEXT_PUBLIC_HORO_WHATSAPP_SUPPORT_URL=
# NEXT_PUBLIC_HORO_WHATSAPP_TRACKING_URL=
# NEXT_PUBLIC_HORO_SUPPORT_EFFECTIVE_DATE=
