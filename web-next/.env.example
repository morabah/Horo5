# Copy to .env.local and set (no trailing slash on URLs).
#
# Dev backend selection (web-next; run commands from this web-next/ directory):
#   npm run dev:local   → frees ports 9000/3000 if busy, starts ../medusa-backend, waits for /health, then Next (Ctrl+C stops both)
#   npm run dev:railway → Next only; uses .env.railway + optional .env.railway.local after .env.local
#
# Local Medusa: http://localhost:9000
# Production Medusa (Railway): https://horo5-production.up.railway.app
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# From Medusa Admin → Settings → Publishable API Keys (must match the backend above)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
